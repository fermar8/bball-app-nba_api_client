# AWS / S3
AWS_ACCOUNT_ID=
S3_BUCKET_NAME=

# Flask
FLASK_DEBUG=0

# Global scheduler switch
ENABLE_IN_PROCESS_SCHEDULER=false

# Endpoint-triggered S3 upload switch
ENABLE_ENDPOINT_S3_UPLOAD=true

# S3 object tagging switch (stage/source/endpoint/processed)
ENABLE_S3_OBJECT_TAGGING=true

# ScheduleLeagueV2 raw ingestion job
SCHEDULE_JOB_ENABLED=true
SCHEDULE_JOB_HOUR_UTC=3
SCHEDULE_JOB_MINUTE_UTC=0
SCHEDULE_JOB_RUN_ON_STARTUP=false
# Optional: force season (YYYY). Example: 2023 -> season 2023-24
SCHEDULE_DEFAULT_SEASON_YEAR=

# ScoreboardV2 raw ingestion job
SCOREBOARD_JOB_ENABLED=false
SCOREBOARD_JOB_HOUR_UTC=5
SCOREBOARD_JOB_MINUTE_UTC=0
SCOREBOARD_JOB_RUN_ON_STARTUP=false
# Optional: MM/DD/YYYY. If empty, endpoint default behavior is used.
SCOREBOARD_GAME_DATE=

# Teams static raw ingestion job
TEAMS_JOB_ENABLED=false
TEAMS_JOB_HOUR_UTC=4
TEAMS_JOB_MINUTE_UTC=0

# PlayerIndex raw ingestion job
PLAYER_INDEX_JOB_ENABLED=false
PLAYER_INDEX_JOB_HOUR_UTC=4
PLAYER_INDEX_JOB_MINUTE_UTC=30

# PlayerGameLogs participant-driven raw ingestion job
PLAYER_GAME_LOGS_JOB_ENABLED=false
PLAYER_GAME_LOGS_JOB_HOUR_UTC=6
PLAYER_GAME_LOGS_JOB_MINUTE_UTC=0
# Optional season (example: 2025-26)
PLAYER_GAME_LOGS_SEASON=

# PlayerNextNGames participant-driven raw ingestion job
PLAYER_NEXT_GAMES_JOB_ENABLED=false
PLAYER_NEXT_GAMES_JOB_HOUR_UTC=6
PLAYER_NEXT_GAMES_JOB_MINUTE_UTC=30
PLAYER_NEXT_GAMES_NUMBER_OF_GAMES=5
# Optional season (example: 2025-26)
PLAYER_NEXT_GAMES_SEASON=

# Participant discovery controls for player jobs
# Optional explicit date MM/DD/YYYY. If set, it overrides lookback.
PLAYER_PARTICIPANT_GAME_DATE=
# Default 1 means "yesterday only"
PLAYER_PARTICIPANT_LOOKBACK_DAYS=1
PLAYER_JOB_MAX_PLAYERS_PER_RUN=150

# nba_api resilience controls
NBA_API_TIMEOUT_SECONDS=15
NBA_API_MAX_RETRIES=2
NBA_API_REQUEST_DELAY_MS=300
NBA_API_BACKOFF_BASE_SECONDS=1
NBA_API_MAX_CONSECUTIVE_ERRORS=5
